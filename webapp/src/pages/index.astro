---
import { getCollection, render } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';

const allChapters = await getCollection('chapters');
const sortedChapters = allChapters.sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <Sidebar chapters={sortedChapters} />
  
  <main class="main">
    {sortedChapters.map(async (chapter) => {
        const { Content } = await render(chapter);
        return (
            <article class="chapter" id={`chapter-${chapter.data.order}`}>
                <div class="chapter-label">Chapter {chapter.data.order.toString().padStart(2, '0')}</div>
                <div class="prose">
                  <Content />
                </div>
            </article>
        );
    })}
  </main>
</Layout>

<script>
// Single Chapter View Logic
document.addEventListener('DOMContentLoaded', () => {
  const sections = Array.from(document.querySelectorAll('.chapter')) as HTMLElement[];
  const navItems = Array.from(document.querySelectorAll('.nav-item')) as HTMLElement[];
  
  if (!sections.length) return;

  // Dynamic Navigation container
  const navContainer = document.createElement('div');
  navContainer.className = 'nav-buttons';
  
  const prevBtn = document.createElement('a');
  prevBtn.className = 'nav-btn prev';
  
  const nextBtn = document.createElement('a');
  nextBtn.className = 'nav-btn next';
  
  navContainer.appendChild(prevBtn);
  navContainer.appendChild(nextBtn);

  function getNavText(navItem: HTMLElement) {
    if (!navItem) return '';
    const clone = navItem.cloneNode(true) as HTMLElement;
    const num = clone.querySelector('.chapter-num');
    if (num) num.remove();
    return clone.textContent?.trim() || '';
  }

  function navigateTo(id: string) {
    const currentIndex = sections.findIndex(sec => sec.id === id);
    if (currentIndex === -1) return;

    history.pushState(null, '', '#' + id);

    sections.forEach(sec => {
      sec.style.display = 'none';
      sec.classList.remove('active');
    });
    
    sections[currentIndex].style.display = 'block';
    sections[currentIndex].appendChild(navContainer);
    // Slight delay for animation
    setTimeout(() => {
      sections[currentIndex].classList.add('active');
    }, 10);

    if (currentIndex > 0) {
      const prevSection = sections[currentIndex - 1];
      const prevNav = navItems.find(nav => nav.getAttribute('href') === '#' + prevSection.id);
      prevBtn.innerHTML = `<span class="dir">Previous</span><span class="title">${prevNav ? getNavText(prevNav) : prevSection.id}</span>`;
      prevBtn.onclick = (e) => { e.preventDefault(); navigateTo(prevSection.id); window.scrollTo(0,0); };
      prevBtn.style.visibility = 'visible';
    } else {
      prevBtn.style.visibility = 'hidden';
    }

    if (currentIndex < sections.length - 1) {
      const nextSection = sections[currentIndex + 1];
      const nextNav = navItems.find(nav => nav.getAttribute('href') === '#' + nextSection.id);
      nextBtn.innerHTML = `<span class="dir">Next</span><span class="title">${nextNav ? getNavText(nextNav) : nextSection.id}</span>`;
      nextBtn.onclick = (e) => { e.preventDefault(); navigateTo(nextSection.id); window.scrollTo(0,0); };
      nextBtn.style.visibility = 'visible';
    } else {
      nextBtn.style.visibility = 'hidden';
    }

    navItems.forEach(item => item.classList.remove('active'));
    const activeNav = navItems.find(nav => nav.getAttribute('href') === '#' + id);
    if (activeNav) {
      activeNav.classList.add('active');
      activeNav.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  const hash = window.location.hash.substring(1);
  if (hash && sections.some(sec => sec.id === hash)) {
    navigateTo(hash);
  } else {
    navigateTo(sections[0].id);
  }

  navItems.forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const id = item.getAttribute('href')?.substring(1);
      if (id) navigateTo(id);
    });
  });
});
</script>
